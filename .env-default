APP_ENV=development
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tbl
DB_USER=root
DB_PASS=root1234
REDIS_URL=redis://127.0.0.1:6379/0
# Заменить ключ перед деплоем в production.
AUTH_SECRET_KEY=change_before_use
AUTH_COOKIE_NAME=practise_auth
AUTH_SESSION_MAX_AGE_SECONDS=43200
AUTH_COOKIE_SECURE=false
CSRF_COOKIE_NAME=practise_csrf
LOGO_CACHE_TTL_SECONDS=86400
LOGO_BATCH_MAX_IDS=80
DOCKER_DB_NAME=tbl
DOCKER_DB_PASS=root
